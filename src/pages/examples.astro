---
import Layout from '../layouts/Layout.astro';
---

<Layout title="示例 | DORA 中文社区" description="DORA 示例与最佳实践索引（持续完善）。">
  <div class="mx-auto max-w-6xl px-4 py-12">
    <h1 class="text-3xl font-semibold tracking-tight text-slate-900">示例</h1>
    <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-600">
      目标是提供“拿来就能跑”的最小可行示例，并附带常见坑位与调试建议。
    </p>

    <div class="mt-10 grid gap-4 md:grid-cols-3">
      {[
        { title: 'Python 节点入门', desc: '最小节点、输入输出与日志。' },
        { title: 'YAML 数据流', desc: '如何组织节点、连接与参数。' },
        { title: '可观测性', desc: '日志/追踪/指标的基础接入。' },
      ].map((card) => (
        <div class="rounded-2xl bg-white p-6 ring-1 ring-slate-200 shadow-sm transition hover:shadow-md">
          <div class="text-base font-semibold text-slate-900">{card.title}</div>
          <div class="mt-2 text-sm text-slate-600">{card.desc}</div>
          <div class="mt-4 text-xs text-slate-500">即将上线</div>
        </div>
      ))}
    </div>
  </div>
</Layout>

