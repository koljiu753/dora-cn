---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import DocsNav from '../../components/DocsNav.astro';
import CommandBlock from '../../components/CommandBlock.astro';
---

<Layout title="文档：性能优化 | Dora 中文站" description="Dora 性能优化：基线建立、结构优化和参数调优的实操顺序。" lang="zh-CN">
  <div class="page-shell">
    <SiteHeader current="docs" />

    <main class="subpage">
      <section class="container breadcrumb-row">
        <a href="/">首页</a>
        <span>/</span>
        <a href="/docs">文档</a>
        <span>/</span>
        <strong>性能优化</strong>
      </section>

      <section class="container doc-layout">
        <DocsNav active="performance" />

        <article class="doc-content">
          <p class="section-tag">文档主题</p>
          <h1>性能优化：先做结构优化，再做参数微调</h1>
          <p>推荐遵循“基线建立 → 热点识别 → 结构优化 → 参数调优”的顺序，避免陷入局部最优。</p>

          <section class="doc-section">
            <h2>优化前必须先有基线</h2>
            <ul class="checklist">
              <li>端到端延迟（P50/P95）</li>
              <li>关键节点吞吐与失败率</li>
              <li>峰值时队列堆积曲线</li>
            </ul>
          </section>

          <section class="doc-section">
            <h2>基线采样命令</h2>
            <CommandBlock
              title="建议采样流程"
              code={`npm run build\ncmd /c npm run preview\n# 在压测期间记录 P50/P95 与失败率`}
              hint="每次优化前后都执行同一采样流程"
            />
          </section>

          <section class="doc-section">
            <h2>优化策略对照</h2>
            <div class="table-wrap">
              <table class="doc-table" aria-label="性能优化策略对照表">
                <thead>
                  <tr>
                    <th>问题类型</th>
                    <th>优先动作</th>
                    <th>后续动作</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td>高耗时节点集中</td>
                    <td>拆分热点节点</td>
                    <td>微调并发与重试参数。</td>
                  </tr>
                  <tr>
                    <td>峰值时队列堆积</td>
                    <td>引入异步缓冲</td>
                    <td>扩展处理节点吞吐能力。</td>
                  </tr>
                  <tr>
                    <td>重复计算开销大</td>
                    <td>缓存稳定输入</td>
                    <td>按业务粒度调整失效策略。</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </section>

          <section class="subpage-cta">
            <a class="button button--primary" href="/quickstart">回到快速开始</a>
            <a class="button button--ghost" href="/docs/observability">上一篇：观测与调试</a>
          </section>
        </article>
      </section>
    </main>

    <SiteFooter />
  </div>
</Layout>
