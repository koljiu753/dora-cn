---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import DocsNav from '../../components/DocsNav.astro';
import CommandBlock from '../../components/CommandBlock.astro';
---

<Layout title="文档：节点模型 | Dora 中文站" description="Dora 节点模型：输入、处理、输出分层和数据契约设计实践。" lang="zh-CN">
  <div class="page-shell">
    <SiteHeader current="docs" />

    <main class="subpage">
      <section class="container breadcrumb-row">
        <a href="/">首页</a>
        <span>/</span>
        <a href="/docs">文档</a>
        <span>/</span>
        <strong>节点模型</strong>
      </section>

      <section class="container doc-layout">
        <DocsNav active="node-model" />

        <article class="doc-content">
          <p class="section-tag">文档主题</p>
          <h1>节点模型：把复杂系统拆成可替换、可维护的职责单元</h1>
          <p>建议按照输入、处理、输出三层拆分节点，并为每层定义稳定的数据契约。</p>

          <section class="doc-section">
            <h2>分层建议</h2>
            <div class="mini-grid">
              <article class="mini-card">
                <h3>输入层</h3>
                <p>采集音频、图像、传感器或外部事件，负责标准化和去抖。</p>
              </article>
              <article class="mini-card">
                <h3>处理层</h3>
                <p>推理、检索、工具调用与状态管理，确保节点职责单一。</p>
              </article>
              <article class="mini-card">
                <h3>输出层</h3>
                <p>统一响应格式并下发到 UI、设备或外部服务。</p>
              </article>
            </div>
          </section>

          <section class="doc-section">
            <h2>节点契约模板</h2>
            <CommandBlock
              title="统一事件结构"
              code={`{\n  "event_id": "string",\n  "timestamp": 1710000000,\n  "payload": {},\n  "trace": {\n    "source": "node_name",\n    "version": "v1"\n  }\n}`}
              hint="版本字段有助于平滑迁移"
            />
          </section>

          <section class="doc-section">
            <h2>建模错误对照</h2>
            <div class="table-wrap">
              <table class="doc-table" aria-label="建模错误对照表">
                <thead>
                  <tr>
                    <th>错误模式</th>
                    <th>风险</th>
                    <th>改进建议</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td>单节点职责过重</td>
                    <td>性能抖动和排障困难叠加</td>
                    <td>按职责拆分并增加边界日志。</td>
                  </tr>
                  <tr>
                    <td>跨节点隐式共享状态</td>
                    <td>一致性问题难复现</td>
                    <td>改为显式事件传递和状态快照。</td>
                  </tr>
                  <tr>
                    <td>接口无版本字段</td>
                    <td>升级时联动风险高</td>
                    <td>引入版本号并提供双版本过渡期。</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </section>

          <section class="subpage-cta">
            <a class="button button--primary" href="/docs/observability">下一篇：观测与调试</a>
            <a class="button button--ghost" href="/docs/architecture">上一篇：架构定位</a>
          </section>
        </article>
      </section>
    </main>

    <SiteFooter />
  </div>
</Layout>
