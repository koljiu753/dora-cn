---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import DocsNav from '../../components/DocsNav.astro';
import CommandBlock from '../../components/CommandBlock.astro';
---

<Layout title="文档：架构定位 | Dora 中文站" description="Dora 架构定位：明确何时应该使用 Dora，何时应选择更轻量方案。" lang="zh-CN">
  <div class="page-shell">
    <SiteHeader current="docs" />

    <main class="subpage">
      <section class="container breadcrumb-row">
        <a href="/">首页</a>
        <span>/</span>
        <a href="/docs">文档</a>
        <span>/</span>
        <strong>架构定位</strong>
      </section>

      <section class="container doc-layout">
        <DocsNav active="architecture" />

        <article class="doc-content">
          <p class="section-tag">文档主题</p>
          <h1>架构定位：先判断边界，再决定是否引入 Dora</h1>
          <p>
            Dora 适合实时 AI 系统中的事件驱动编排场景。它解决的是“持续运行链路如何组织和演进”的问题，而不是单次调用的脚本执行问题。
          </p>

          <section class="doc-section">
            <h2>适合引入 Dora 的信号</h2>
            <ul class="checklist">
              <li>应用需要持续运行并处理高频事件流。</li>
              <li>系统包含多个可替换节点，且链路会持续演化。</li>
              <li>团队需要节点级可观测与可回放能力。</li>
            </ul>
          </section>

          <section class="doc-section">
            <h2>场景决策速查</h2>
            <div class="table-wrap">
              <table class="doc-table" aria-label="架构定位速查表">
                <thead>
                  <tr>
                    <th>场景信号</th>
                    <th>建议</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td>持续语音/视觉输入 + 实时输出</td>
                    <td>优先考虑 Dora，先做最小闭环 PoC。</td>
                  </tr>
                  <tr>
                    <td>多节点协作且经常替换组件</td>
                    <td>引入 Dora，先统一节点契约。</td>
                  </tr>
                  <tr>
                    <td>一次性离线任务</td>
                    <td>先用轻量方案，保留后续迁移空间。</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </section>

          <section class="doc-section">
            <h2>PoC 快速验证命令</h2>
            <CommandBlock
              title="最小闭环验证"
              code={`npm install\nnpm run dev\nnpm run build`}
              hint="先验证流程，再决定是否扩展架构"
            />
          </section>

          <section class="subpage-cta">
            <a class="button button--primary" href="/docs/node-model">下一篇：节点模型</a>
            <a class="button button--ghost" href="/quickstart">去快速开始</a>
          </section>
        </article>
      </section>
    </main>

    <SiteFooter />
  </div>
</Layout>
