---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import DocsNav from '../../components/DocsNav.astro';
import CommandBlock from '../../components/CommandBlock.astro';
---

<Layout title="文档：观测与调试 | Dora 中文站" description="Dora 观测与调试：排障顺序、关键指标与故障回放建议。" lang="zh-CN">
  <div class="page-shell">
    <SiteHeader current="docs" />

    <main class="subpage">
      <section class="container breadcrumb-row">
        <a href="/">首页</a>
        <span>/</span>
        <a href="/docs">文档</a>
        <span>/</span>
        <strong>观测与调试</strong>
      </section>

      <section class="container doc-layout">
        <DocsNav active="observability" />

        <article class="doc-content">
          <p class="section-tag">文档主题</p>
          <h1>观测与调试：固定排障顺序，减少盲目试错</h1>
          <p>先输入、再处理、后输出是推荐排障顺序。流程固定后，团队排障速度和一致性会明显提升。</p>

          <section class="doc-section">
            <h2>推荐排障顺序</h2>
            <ol class="timeline">
              <li>
                <strong>输入稳定性检查</strong>
                <p>确认事件格式、频率、时间戳是否稳定，先排除上游抖动。</p>
              </li>
              <li>
                <strong>处理节点耗时分析</strong>
                <p>定位耗时 top 节点，优先拆分热点节点而不是全局重构。</p>
              </li>
              <li>
                <strong>输出阻塞与回压检查</strong>
                <p>观察回调超时、队列堆积和外部依赖抖动。</p>
              </li>
            </ol>
          </section>

          <section class="doc-section">
            <h2>日志模板</h2>
            <CommandBlock
              title="节点日志示例"
              code={`{\n  "trace_id": "abc-123",\n  "node": "speech_to_text",\n  "latency_ms": 82,\n  "status": "ok",\n  "timestamp": 1710000000\n}`}
              hint="建议每个节点统一输出 trace_id 与 latency_ms"
            />
          </section>

          <section class="doc-section">
            <h2>故障现象对照</h2>
            <div class="table-wrap">
              <table class="doc-table" aria-label="故障现象对照表">
                <thead>
                  <tr>
                    <th>现象</th>
                    <th>优先排查点</th>
                    <th>常见修复动作</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td>整体延迟突增</td>
                    <td>处理层热点节点</td>
                    <td>拆分节点并降低同步阻塞。</td>
                  </tr>
                  <tr>
                    <td>间歇性输出丢失</td>
                    <td>输出层回调与队列</td>
                    <td>补重试与超时告警策略。</td>
                  </tr>
                  <tr>
                    <td>结果顺序错乱</td>
                    <td>输入层时间戳与事件 ID</td>
                    <td>增加事件去重与顺序校验。</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </section>

          <section class="subpage-cta">
            <a class="button button--primary" href="/docs/performance">下一篇：性能优化</a>
            <a class="button button--ghost" href="/docs/node-model">上一篇：节点模型</a>
          </section>
        </article>
      </section>
    </main>

    <SiteFooter />
  </div>
</Layout>
