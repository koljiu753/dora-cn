---
import '../styles/global.css';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Seo from '../components/Seo.astro';

type Props = {
  title?: string;
  description?: string;
  noindex?: boolean;
  ogImage?: `/${string}`;
};

const {
  title = 'DORA 中文社区',
  description = '为 AI 时代打造的现代机器人开发框架。极简 · 安全 · 高效。',
  noindex = false,
  ogImage = '/logo.png',
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffffff" />
    <meta name="format-detection" content="telephone=no" />

    <title>{title}</title>

    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="apple-touch-icon" href="/logo.png" />

    <Seo title={title} description={description} noindex={noindex} ogImage={ogImage} />
  </head>
  <body class="min-h-dvh bg-white text-slate-900 antialiased">
    <a class="skip-link" href="#main">跳到主要内容</a>
    <Header />
    <main id="main" class="min-h-[calc(100dvh-64px)]">
      <slot />
    </main>
    <Footer />
  </body>
</html>
