---
const { active = 'architecture' } = Astro.props;

const items = [
  { key: 'architecture', label: '架构定位', href: '/docs/architecture' },
  { key: 'node-model', label: '节点模型', href: '/docs/node-model' },
  { key: 'observability', label: '观测与调试', href: '/docs/observability' },
  { key: 'performance', label: '性能优化', href: '/docs/performance' },
];
---

<aside class="doc-nav" aria-label="文档主题导航">
  <h2>文档主题</h2>
  <nav>
    {items.map((item) => (
      <a href={item.href} aria-current={active === item.key ? 'page' : undefined}>{item.label}</a>
    ))}
  </nav>
  <a class="button button--ghost" href="/docs">返回文档总览</a>
</aside>
