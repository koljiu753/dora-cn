---
const { title = '命令', code = '', hint } = Astro.props;
---

<div class="command-block">
  <div class="command-block__head">
    <h3>{title}</h3>
    <button type="button" class="copy-button">复制命令</button>
  </div>
  <pre><code>{code}</code></pre>
  {hint && <p class="command-block__hint">{hint}</p>}

  <script is:inline>
    (() => {
      const root = document.currentScript?.parentElement;
      if (!root) return;

      const button = root.querySelector('.copy-button');
      const codeElement = root.querySelector('pre code');
      if (!button || !codeElement) return;

      const resetText = () => {
        button.textContent = '复制命令';
      };

      button.addEventListener('click', async () => {
        const content = codeElement.textContent ?? '';
        if (!content.trim()) return;

        try {
          await navigator.clipboard.writeText(content);
          button.textContent = '已复制';
          window.setTimeout(resetText, 1400);
        } catch {
          button.textContent = '复制失败';
          window.setTimeout(resetText, 1400);
        }
      });
    })();
  </script>
</div>
