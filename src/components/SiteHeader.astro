---
const { current = 'home' } = Astro.props;

const navItems = [
  { key: 'home', label: '首页', href: '/' },
  { key: 'docs', label: '文档', href: '/docs' },
  { key: 'quickstart', label: '快速开始', href: '/quickstart' },
  { key: 'cases', label: '案例', href: '/cases' },
  { key: 'ecosystem', label: '生态', href: '/ecosystem' },
];
---

<header class="site-header">
  <div class="site-header__inner container">
    <a class="site-logo" href="/" aria-label="Dora 中文站首页">
      <span class="site-logo__mark" aria-hidden="true">D</span>
      <span class="site-logo__text">
        <small>DORA-CHINA</small>
        <strong>Dora 中文站</strong>
      </span>
    </a>

    <nav class="site-nav" aria-label="主导航">
      {navItems.map((item) => (
        <a href={item.href} aria-current={current === item.key ? 'page' : undefined}>{item.label}</a>
      ))}
    </nav>

    <a class="site-header__cta" href="/quickstart">立即开始</a>
  </div>
</header>
