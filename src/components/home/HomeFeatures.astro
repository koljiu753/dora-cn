---
const features = [
  {
    icon: '⭐',
    title: '零开销通信',
    desc: '共享内存 + Apache Arrow，单机内零拷贝传输。',
    href: 'https://dora-rs.ai/',
    linkText: '了解特性',
  },
  {
    icon: '🤯',
    title: '可扩展的数据流',
    desc: '用 YAML 描述图结构，便于多机分布与组合。',
    href: 'https://dora-rs.ai/docs/api/dataflow-config',
    linkText: '数据流配置',
  },
  {
    icon: '👨‍🏭',
    title: '快速原型',
    desc: 'YAML 引用现成节点，Python 热重载边改边跑。',
    href: 'https://dora-rs.ai/docs/guides/Development/hot-reload',
    linkText: '热重载',
  },
  {
    icon: '🔭',
    title: '可观测',
    desc: 'CLI 与 OpenTelemetry 支持日志、追踪与指标。',
    href: 'https://dora-rs.ai/docs/guides/Debugging/logs',
    linkText: '日志与调试',
  },
  {
    icon: '💻',
    title: '多语言与平台',
    desc: 'Python、Rust、C、C++；覆盖常见系统与架构。',
    href: 'https://dora-rs.ai/docs/guides/support-matrix',
    linkText: '支持矩阵',
  },
  {
    icon: '🧑‍🤝‍🧑',
    title: '社区',
    desc: '开源协作，与全球开发者一起改进 dora。',
    href: 'https://discord.gg/DXJ6edAtym',
    linkText: 'Discord',
  },
];
---

<section id="features" class="scroll-mt-24 py-14 md:py-16" aria-labelledby="features-heading">
  <div class="mx-auto max-w-6xl px-4">
    <h2 id="features-heading" class="text-2xl font-semibold tracking-tight text-slate-900 md:text-3xl">
      为什么选择 dora-rs
    </h2>
    <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-600 md:text-base">
      与国际站 <a href="https://dora-rs.ai/" class="font-medium text-[#000063] underline underline-offset-2" target="_blank" rel="noreferrer">Features</a> 对齐，点击卡片直达官方文档章节。
    </p>

    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((f) => (
        <article class="flex flex-col rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:shadow-md">
          <div class="text-2xl" aria-hidden="true">
            {f.icon}
          </div>
          <h3 class="mt-3 text-base font-semibold text-slate-900">{f.title}</h3>
          <p class="mt-2 flex-1 text-sm leading-6 text-slate-600">{f.desc}</p>
          <a
            href={f.href}
            target="_blank"
            rel="noreferrer"
            class="mt-4 inline-flex text-sm font-medium text-[#000063] hover:underline"
          >
            {f.linkText} →
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
