---
const nav: { href: string; label: string; external?: boolean }[] = [
  { href: 'https://dora-rs.ai/docs/guides', label: '官方文档', external: true },
  { href: '/tutorial', label: '教程' },
  { href: '/examples', label: '示例' },
  { href: '/community', label: '中文社区' },
  { href: '/about', label: '关于' },
];

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header id="site-header" class="sticky top-0 z-50 border-b border-slate-200/70 bg-white/80 backdrop-blur transition-shadow duration-200">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4">
    <a href="/" class="group inline-flex items-center gap-2">
      <img
        src="/logo.png"
        alt="DORA 中文社区"
        width="32"
        height="32"
        class="size-8 rounded-lg ring-1 ring-slate-200 object-contain bg-white"
        onerror="this.style.display='none'; this.nextElementSibling?.classList.remove('hidden');"
      />
      <span
        class="hidden size-8 items-center justify-center rounded-lg bg-slate-900 text-sm font-black text-white"
        aria-hidden="true"
        >D</span
      >
      <span class="text-sm font-semibold tracking-tight text-slate-900">DORA 中文社区</span>
    </a>

    <nav class="hidden items-center gap-5 md:flex" aria-label="主导航">
      {nav.map((item) => (
        <a
          href={item.href}
          aria-current={!item.external && pathname === item.href ? 'page' : undefined}
          target={item.external ? '_blank' : undefined}
          rel={item.external ? 'noreferrer' : undefined}
          class:list={[
            'text-sm transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#000063]/35 rounded-md px-2 py-1 -mx-2',
            !item.external && pathname === item.href
              ? 'text-[#000063] bg-[#000063]/8 font-medium'
              : 'text-slate-700 hover:text-[#000063] hover:bg-slate-900/5',
          ]}
        >
          {item.label}
        </a>
      ))}
      <div class="h-5 w-px bg-slate-200"></div>
      <a
        href="https://github.com/dora-rs/dora"
        class="inline-flex items-center rounded-lg bg-[#000063] px-3 py-1.5 text-sm font-medium text-white transition hover:bg-[#0a0a7a] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#000063]/40"
        target="_blank"
        rel="noreferrer"
      >
        GitHub
      </a>
    </nav>

    <button
      class="inline-flex items-center justify-center rounded-lg bg-[#000063] px-3 py-2 text-sm font-medium text-white transition hover:bg-[#0a0a7a] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#000063]/40 md:hidden"
      id="menuButton"
      type="button"
      aria-expanded="false"
      aria-controls="mobileMenu"
    >
      菜单
    </button>
  </div>

  <div id="mobileMenu" class="hidden border-t border-slate-200 md:hidden">
    <div class="mx-auto max-w-6xl px-4 py-3">
      <nav class="grid gap-2" aria-label="移动端主导航">
        {nav.map((item) => (
          <a
            href={item.href}
            aria-current={!item.external && pathname === item.href ? 'page' : undefined}
            target={item.external ? '_blank' : undefined}
            rel={item.external ? 'noreferrer' : undefined}
            class:list={[
              'rounded-lg px-3 py-2 text-sm transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#000063]/35',
              !item.external && pathname === item.href
                ? 'bg-[#000063]/8 font-medium text-[#000063]'
                : 'text-slate-700 hover:bg-slate-50 hover:text-[#000063]',
            ]}
          >
            {item.label}
          </a>
        ))}
        <a
          href="https://github.com/dora-rs/dora"
          class="rounded-lg bg-[#000063] px-3 py-2 text-sm font-medium text-white transition hover:bg-[#0a0a7a]"
          target="_blank"
          rel="noreferrer"
        >
          GitHub
        </a>
      </nav>
    </div>
  </div>

  <script>
    const btn = document.getElementById('menuButton');
    const menu = document.getElementById('mobileMenu');
    if (btn && menu) {
      btn.addEventListener('click', () => {
        const expanded = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', expanded ? 'false' : 'true');
        menu.classList.toggle('hidden', expanded);
      });

      // Close menu on route click
      menu.addEventListener('click', (e) => {
        const target = e.target;
        if (target instanceof HTMLAnchorElement) {
          btn.setAttribute('aria-expanded', 'false');
          menu.classList.add('hidden');
        }
      });
    }

    const header = document.getElementById('site-header');
    const onScroll = () => {
      if (!header) return;
      const y = window.scrollY;
      header.classList.toggle('shadow-md', y > 4);
      header.classList.toggle('bg-white/95', y > 4);
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  </script>
</header>

